{
  "tasks": {
    "wasmbuild": "deno run -A jsr:@deno/wasmbuild",
    "genkey": "deno run --allow-read=./lib/rs_lib_bg.wasm --allow-write=master.key generate_key.ts",
    "server": "deno serve -P server.ts",
    "build": "deno bundle client/mod.ts --sourcemap -o=client/mod.js"
  },
  "imports": {
    "@deno/wasmbuild": "jsr:@deno/wasmbuild@^0.21.1",
    "@hono/hono": "jsr:@hono/hono@^4.12.9",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/msgpack": "jsr:@std/msgpack@^1.0.3"
  },
  "permissions": {
    "default": {
      "read": ["./lib/", "master.key"],
      "env": ["IBKEM_SECRET_KEY"]
    }
  }
}
